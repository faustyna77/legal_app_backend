# Neon.tech → projekt → Connection string (psycopg2)
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Losowy string: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change-me-secret

# OpenAI API key (chat + embeddings)
OPENAI_API_KEY=sk-...

# Opcjonalnie: zmień model (domyślne wartości poniżej)
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Tylko jeśli używasz Celery pipeline
REDIS_URL=redis://localhost:6379/0

ALLOWED_ORIGINS=http://localhost:3000
