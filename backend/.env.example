# Neon.tech → projekt → Connection string (psycopg2)
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Losowy string: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change-me-secret

# Jina AI → do embeddingów (jina-embeddings-v3, 1024 dim, 1M tokenów/mies. gratis)
# jina.ai → Get API Key
JINA_API_KEY=jina_...

# Groq → do generowania odpowiedzi LLM
# console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Opcjonalnie: zmień model (domyślne wartości poniżej)
# Groq modele: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=jina-embeddings-v3

# Tylko jeśli używasz Celery pipeline
REDIS_URL=redis://localhost:6379/0

ALLOWED_ORIGINS=http://localhost:3000
